{
  "description": "Block git identity overrides (ADR 0003) and enforce the write-ahead compaction invariant (ADR 0013).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/git-identity-guard.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/precompact-write-ahead-backstop.sh\""
          }
        ]
      }
    ]
  }
}
